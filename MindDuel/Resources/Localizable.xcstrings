            "value" : "Dine data og rettigheter"
          }
        }
      }
    },
    "terms_section_privacy_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use Sign in with Apple. Your username, score and game history are stored to power friends, leaderboards and progression. Your real name and email are never shared with other players."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi bruker Logg inn med Apple. Brukernavn, poengsum og spillhistorikk lagres for å drive venner, scoreboards og fremgang. Ditt fulle navn og e-post deles aldri med andre spillere."
          }
        }
      }
    },
    "terms_section_privacy_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Personvern"
          }
        }
      }
    },
    "terms_section_terms_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MindDuel is provided as-is for personal use. By using the app you agree to play fair and not to attempt to circumvent the daily question quota or anti-cheat systems. We may suspend accounts that show automated or otherwise abusive behavior."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MindDuel leveres som det er, til personlig bruk. Ved å bruke appen samtykker du til å spille rent og ikke forsøke å omgå daglig spørsmålskvote eller anti-juks-systemene. Vi kan suspendere kontoer som viser automatisert eller på annen måte misbrukende adferd."
          }
        }
      }
    },
