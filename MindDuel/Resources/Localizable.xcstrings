    "terms_section_data_body" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can request a copy of your data and delete your account at any time from Settings → Delete account and data. Data is hosted in the EU."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan be om en kopi av dine data og slette kontoen din når som helst fra Innstillinger → Slett konto og data. Data lagres i EU."
          }
        }
      }
    },
    "terms_section_data_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your data and rights"
          }
