<h1 class="text-2xl font-bold mb-8">Statistics</h1>

<!-- Key metrics -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-indigo-400"><%= stats.dau %></div>
    <div class="text-sm text-gray-400 mt-1">Aktive i dag (24t)</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-green-400"><%= stats.mau %></div>
    <div class="text-sm text-gray-400 mt-1">Aktive siste 30 dager</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-white"><%= stats.totalUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Total brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-amber-400"><%= stats.premiumUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Premium brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-white"><%= stats.totalSessions %></div>
    <div class="text-sm text-gray-400 mt-1">Totale spilløkter</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-green-400"><%= stats.sessionsToday %></div>
    <div class="text-sm text-gray-400 mt-1">Spilløkter i dag</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-amber-400"><%= stats.flaggedUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Flaggede brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-red-400"><%= stats.openFeedback %></div>
    <div class="text-sm text-gray-400 mt-1">Åpen tilbakemelding</div>
  </div>
</div>

<!-- Mode popularity + accuracy side by side -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Spillmodus popularitet (30d)</h2>
    <% modePopularity.forEach(function(m) { %>
      <div class="flex items-center gap-3 mb-2">
        <span class="w-20 text-sm text-gray-400"><%= m.mode %></span>
        <div class="flex-1 bg-gray-800 rounded-full h-2">
          <div class="bg-indigo-500 h-2 rounded-full"
            style="width: <%= modePopularity[0].count > 0 ? Math.round(m.count/modePopularity[0].count*100) : 0 %>%"></div>
        </div>
        <span class="text-sm text-gray-400 w-12 text-right"><%= m.count %></span>
      </div>
    <% }) %>
    <% if (!modePopularity.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Andel riktige svar per modus</h2>
    <% modeAccuracy.forEach(function(m) { %>
      <div class="flex items-center gap-3 mb-2">
        <span class="w-20 text-sm text-gray-400"><%= m.mode %></span>
        <div class="flex-1 bg-gray-800 rounded-full h-2">
          <% var pct = m.pct ?? 0 %>
          <div class="h-2 rounded-full <%= pct >= 70 ? 'bg-green-500' : pct >= 50 ? 'bg-amber-500' : 'bg-red-500' %>"
            style="width: <%= pct %>%"></div>
        </div>
        <span class="text-sm w-12 text-right <%= m.pct >= 70 ? 'text-green-400' : m.pct >= 50 ? 'text-amber-400' : 'text-gray-500' %>">
          <%= m.pct !== null ? m.pct + '%' : '–' %>
        </span>
      </div>
    <% }) %>
    <% if (!modeAccuracy.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>
</div>

<!-- Sessions over time -->
<% if (sessionTimeSeries.length > 0) { %>
<div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
  <h2 class="font-semibold mb-4">Spilløkter over tid (siste 30 dager)</h2>
  <div class="overflow-x-auto">
    <div class="flex items-end gap-1 h-32 min-w-max">
      <% var maxSessions = Math.max(...sessionTimeSeries.map(function(d){ return d.single + d.multiplayer }), 1) %>
      <% sessionTimeSeries.forEach(function(d) { %>
        <div class="flex flex-col items-center gap-0.5 group" title="<%= d.date %>: <%= d.single %> single, <%= d.multiplayer %> multiplayer">
          <div class="w-4 flex flex-col justify-end" style="height: 112px;">
            <div class="bg-indigo-500 w-full rounded-t-sm" style="height: <%= Math.round(d.single / maxSessions * 100) %>%"></div>
            <div class="bg-purple-500 w-full" style="height: <%= Math.round(d.multiplayer / maxSessions * 100) %>%"></div>
          </div>
          <span class="text-gray-600 text-xs rotate-45 origin-left hidden group-hover:block absolute mt-2"><%= d.date.slice(5) %></span>
        </div>
      <% }) %>
    </div>
    <div class="flex gap-4 mt-3 text-xs text-gray-400">
      <span class="flex items-center gap-1"><span class="w-3 h-3 bg-indigo-500 rounded-sm inline-block"></span> Singel</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 bg-purple-500 rounded-sm inline-block"></span> Flerspiller</span>
    </div>
  </div>
</div>
<% } %>

<!-- Per-level accuracy -->
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Andel riktige svar per nivå</div>
  <% if (levelAccuracy.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Nivå</th>
        <th class="text-right px-4 py-2">Riktige</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">% riktig</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% levelAccuracy.forEach(function(r) { %>
        <tr>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-medium"><%= r.level %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.correct %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.total %></td>
          <td class="px-4 py-2 text-right">
            <% if (r.pct !== null) { %>
              <span class="<%= r.pct >= 70 ? 'text-green-400' : r.pct >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= r.pct %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen data ennå</p>
  <% } %>
</div>

<!-- Per-age accuracy (mode × level × age group) -->
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Andel riktige svar per alder, modus og nivå</div>
  <% if (ageAccuracy.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Nivå</th>
        <th class="text-left px-4 py-2">Aldersgruppe</th>
        <th class="text-right px-4 py-2">Riktige</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">% riktig</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% ageAccuracy.forEach(function(r) { %>
        <tr>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-medium"><%= r.level %></td>
          <td class="px-4 py-2 text-gray-300"><%= r.ageGroup %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.correct %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.total %></td>
          <td class="px-4 py-2 text-right">
            <% if (r.pct !== null) { %>
              <span class="<%= r.pct >= 70 ? 'text-green-400' : r.pct >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= r.pct %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen data ennå – krever fullførte spilløkter fra brukere med registrert fødselsdato</p>
  <% } %>
</div>

<!-- Age + language -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Aldersfordeling</h2>
    <% if (ageDistribution.length > 0) { %>
      <% var maxAge = Math.max(...ageDistribution.map(function(d){ return d.count }), 1) %>
      <% ageDistribution.forEach(function(d) { %>
        <div class="flex items-center gap-3 mb-2">
          <span class="w-20 text-sm text-gray-400"><%= d.group %></span>
          <div class="flex-1 bg-gray-800 rounded-full h-2">
            <div class="bg-teal-500 h-2 rounded-full" style="width: <%= Math.round(d.count/maxAge*100) %>%"></div>
          </div>
          <span class="text-sm text-gray-400 w-10 text-right"><%= d.count %></span>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-600 text-sm">Ingen fødselsdatoer registrert ennå</p>
    <% } %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Appspråk</h2>
    <% if (localeDistribution.length > 0) { %>
      <% var maxLocale = Math.max(...localeDistribution.map(function(d){ return d.count }), 1) %>
      <% localeDistribution.forEach(function(d) { %>
        <div class="flex items-center gap-3 mb-2">
          <span class="w-24 text-sm text-gray-400 truncate"><%= d.locale %></span>
          <div class="flex-1 bg-gray-800 rounded-full h-2">
            <div class="bg-sky-500 h-2 rounded-full" style="width: <%= Math.round(d.count/maxLocale*100) %>%"></div>
          </div>
          <span class="text-sm text-gray-400 w-10 text-right"><%= d.count %></span>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-600 text-sm">Ingen lokaledata ennå</p>
    <% } %>
  </div>
</div>
