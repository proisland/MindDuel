<h1 class="text-2xl font-bold mb-8">Statistics</h1>

<!-- Key metrics -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-indigo-400"><%= stats.dau %></div>
    <div class="text-sm text-gray-400 mt-1">Aktive i dag (24t)</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-green-400"><%= stats.mau %></div>
    <div class="text-sm text-gray-400 mt-1">Aktive siste 30 dager</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-white"><%= stats.totalUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Total brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-amber-400"><%= stats.premiumUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Premium brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-white"><%= stats.totalSessions %></div>
    <div class="text-sm text-gray-400 mt-1">Totale spilløkter</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-green-400"><%= stats.sessionsToday %></div>
    <div class="text-sm text-gray-400 mt-1">Spilløkter i dag</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-amber-400"><%= stats.flaggedUsers %></div>
    <div class="text-sm text-gray-400 mt-1">Flaggede brukere</div>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <div class="text-3xl font-bold text-red-400"><%= stats.openFeedback %></div>
    <div class="text-sm text-gray-400 mt-1">Åpen tilbakemelding</div>
  </div>
</div>

<!-- Daily quota (free users) -->
<% if (quotaStats) { %>
<div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
  <h2 class="font-semibold mb-4">Dagskvote – gratisbrukere (<%= quotaStats.todayStr %>)</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
    <div>
      <div class="text-2xl font-bold text-indigo-400"><%= quotaStats.activeToday %></div>
      <div class="text-xs text-gray-400 mt-0.5">Har brukt kvote i dag</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-red-400"><%= quotaStats.hitLimit %></div>
      <div class="text-xs text-gray-400 mt-0.5">Nådd daglig grense</div>
    </div>
    <div>
      <div class="text-2xl font-bold text-amber-400"><%= quotaStats.avgUsage !== null ? quotaStats.avgUsage : '–' %></div>
      <div class="text-xs text-gray-400 mt-0.5">Snittforbruk (aktive)</div>
    </div>
  </div>
  <div class="flex gap-1 items-end h-20">
    <% const buckets = [
      { label: '1–5', val: quotaStats.bucket1_5 },
      { label: '6–10', val: quotaStats.bucket6_10 },
      { label: '11–15', val: quotaStats.bucket11_15 },
      { label: '16–19', val: quotaStats.bucket16_19 },
      { label: '20', val: quotaStats.bucket20plus },
    ]
    const maxBucket = Math.max(...buckets.map(b => b.val), 1)
    %>
    <% buckets.forEach(function(b) { %>
      <div class="flex flex-col items-center gap-1 flex-1">
        <span class="text-xs text-gray-400"><%= b.val %></span>
        <div class="w-full rounded-t"
          style="height: <%= Math.round(b.val / maxBucket * 60) %>px; background: <%= b.label === '20' ? '#f87171' : '#6366f1' %>"></div>
        <span class="text-xs text-gray-500"><%= b.label %></span>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Mode popularity + accuracy side by side -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Spillmodus popularitet (30d)</h2>
    <% modePopularity.forEach(function(m) { %>
      <div class="flex items-center gap-3 mb-2">
        <span class="w-20 text-sm text-gray-400"><%= m.mode %></span>
        <div class="flex-1 bg-gray-800 rounded-full h-2">
          <div class="bg-indigo-500 h-2 rounded-full"
            style="width: <%= modePopularity[0].count > 0 ? Math.round(m.count/modePopularity[0].count*100) : 0 %>%"></div>
        </div>
        <span class="text-sm text-gray-400 w-12 text-right"><%= m.count %></span>
      </div>
    <% }) %>
    <% if (!modePopularity.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Andel riktige svar per modus</h2>
    <% modeAccuracy.forEach(function(m) { %>
      <div class="flex items-center gap-3 mb-2">
        <span class="w-20 text-sm text-gray-400"><%= m.mode %></span>
        <div class="flex-1 bg-gray-800 rounded-full h-2">
          <% var pct = m.pct ?? 0 %>
          <div class="h-2 rounded-full <%= pct >= 70 ? 'bg-green-500' : pct >= 50 ? 'bg-amber-500' : 'bg-red-500' %>"
            style="width: <%= pct %>%"></div>
        </div>
        <span class="text-sm w-12 text-right <%= m.pct >= 70 ? 'text-green-400' : m.pct >= 50 ? 'text-amber-400' : 'text-gray-500' %>">
          <%= m.pct !== null ? m.pct + '%' : '–' %>
        </span>
      </div>
    <% }) %>
    <% if (!modeAccuracy.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>
</div>

<!-- Sessions over time -->
<% if (sessionTimeSeries.length > 0) { %>
<div class="bg-gray-900 border border-gray-800 rounded-xl p-6 mb-6">
  <h2 class="font-semibold mb-4">Spilløkter over tid (siste 30 dager)</h2>
  <div class="overflow-x-auto">
    <div class="flex items-end gap-1 min-w-max" style="height: 140px; padding-bottom: 28px;">
      <% var maxSessions = Math.max(...sessionTimeSeries.map(function(d){ return d.single + d.multiplayer }), 1) %>
      <% sessionTimeSeries.forEach(function(d) { %>
        <div class="flex flex-col items-center gap-0.5 group relative" title="<%= d.date %>: <%= d.single %> singel, <%= d.multiplayer %> flerspiller"
          style="<%= d.isMonday ? 'border-left: 1px solid rgba(99,102,241,0.3);' : '' %>">
          <div class="w-5 flex flex-col justify-end rounded-t-sm overflow-hidden" style="height: 96px;">
            <div class="bg-indigo-500 w-full" style="height: <%= Math.round(d.single / maxSessions * 100) %>%"></div>
            <div class="bg-purple-500 w-full" style="height: <%= Math.round(d.multiplayer / maxSessions * 100) %>%"></div>
          </div>
          <span class="text-gray-500 text-xs mt-1 whitespace-nowrap" style="transform: rotate(-45deg); transform-origin: top left; position: absolute; bottom: 0; left: 6px; font-size: 9px;"><%= d.label %></span>
        </div>
      <% }) %>
    </div>
    <div class="flex gap-4 mt-2 text-xs text-gray-400">
      <span class="flex items-center gap-1"><span class="w-3 h-3 bg-indigo-500 rounded-sm inline-block"></span> Singel</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 bg-purple-500 rounded-sm inline-block"></span> Flerspiller</span>
    </div>
  </div>
</div>
<% } %>

<!-- Hourly active users + sessions (last 24h) -->
<% if (hourlyActiveUsers.length > 0 || hourlySessionsRaw.length > 0) { %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Aktive brukere per time (siste 24t)</h2>
    <div class="overflow-x-auto">
      <div class="flex items-end gap-1 min-w-max" style="height: 80px; padding-bottom: 20px;">
        <% var maxHourlyU = Math.max(...hourlyActiveUsers.map(function(h){ return h.users }), 1) %>
        <% hourlyActiveUsers.forEach(function(h) { %>
          <div class="flex flex-col items-center relative" title="<%= h.hour %>: <%= h.users %> brukere">
            <div class="w-5 bg-indigo-500 rounded-t-sm" style="height: <%= Math.round(h.users / maxHourlyU * 52) %>px; min-height: 2px;"></div>
            <span style="transform: rotate(-45deg); transform-origin: top left; position: absolute; bottom: 0; left: 6px; font-size: 9px;" class="text-gray-500"><%= h.hour %></span>
          </div>
        <% }) %>
      </div>
    </div>
    <% if (!hourlyActiveUsers.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Spilløkter per time (siste 24t)</h2>
    <div class="overflow-x-auto">
      <div class="flex items-end gap-1 min-w-max" style="height: 80px; padding-bottom: 20px;">
        <% var maxHourlyS = Math.max(...hourlySessionsRaw.map(function(h){ return h.single + h.multiplayer }), 1) %>
        <% hourlySessionsRaw.forEach(function(h) { %>
          <div class="flex flex-col items-center relative" title="<%= h.hour %>: <%= h.single %> singel, <%= h.multiplayer %> flerspiller">
            <div class="w-5 flex flex-col justify-end rounded-t-sm overflow-hidden" style="height: <%= Math.round((h.single + h.multiplayer) / maxHourlyS * 52) %>px; min-height: 2px;">
              <div class="bg-indigo-500 w-full" style="height: <%= (h.single + h.multiplayer) > 0 ? Math.round(h.single / (h.single + h.multiplayer) * 100) : 0 %>%"></div>
              <div class="bg-purple-500 w-full" style="height: <%= (h.single + h.multiplayer) > 0 ? Math.round(h.multiplayer / (h.single + h.multiplayer) * 100) : 0 %>%"></div>
            </div>
            <span style="transform: rotate(-45deg); transform-origin: top left; position: absolute; bottom: 0; left: 6px; font-size: 9px;" class="text-gray-500"><%= h.hour %></span>
          </div>
        <% }) %>
      </div>
    </div>
    <% if (!hourlySessionsRaw.length) { %><p class="text-gray-600 text-sm">Ingen data ennå</p><% } %>
  </div>
</div>
<% } %>

<!-- Per-level accuracy -->
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Andel riktige svar per nivå</div>
  <% if (levelAccuracy.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Nivå</th>
        <th class="text-right px-4 py-2">Riktige</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">% riktig</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% levelAccuracy.forEach(function(r) { %>
        <tr>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-medium"><%= r.level %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.correct %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.total %></td>
          <td class="px-4 py-2 text-right">
            <% if (r.pct !== null) { %>
              <span class="<%= r.pct >= 70 ? 'text-green-400' : r.pct >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= r.pct %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen data ennå</p>
  <% } %>
</div>

<!-- Per-age accuracy (mode × level × age group) -->
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-6">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Andel riktige svar per alder, modus og nivå</div>
  <% if (ageAccuracy.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Nivå</th>
        <th class="text-left px-4 py-2">Aldersgruppe</th>
        <th class="text-right px-4 py-2">Riktige</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">% riktig</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% ageAccuracy.forEach(function(r) { %>
        <tr>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-medium"><%= r.level %></td>
          <td class="px-4 py-2 text-gray-300"><%= r.ageGroup %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.correct %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.total %></td>
          <td class="px-4 py-2 text-right">
            <% if (r.pct !== null) { %>
              <span class="<%= r.pct >= 70 ? 'text-green-400' : r.pct >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= r.pct %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen data ennå – krever fullførte spilløkter fra brukere med registrert fødselsdato</p>
  <% } %>
</div>

<!-- Age + language -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Aldersfordeling</h2>
    <% if (ageDistribution.length > 0) { %>
      <% var maxAge = Math.max(...ageDistribution.map(function(d){ return d.count }), 1) %>
      <% ageDistribution.forEach(function(d) { %>
        <div class="flex items-center gap-3 mb-2">
          <span class="w-20 text-sm text-gray-400"><%= d.group %></span>
          <div class="flex-1 bg-gray-800 rounded-full h-2">
            <div class="bg-teal-500 h-2 rounded-full" style="width: <%= Math.round(d.count/maxAge*100) %>%"></div>
          </div>
          <span class="text-sm text-gray-400 w-10 text-right"><%= d.count %></span>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-600 text-sm">Ingen fødselsdatoer registrert ennå</p>
    <% } %>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
    <h2 class="font-semibold mb-4">Appspråk</h2>
    <% if (localeDistribution.length > 0) { %>
      <% var maxLocale = Math.max(...localeDistribution.map(function(d){ return d.count }), 1) %>
      <% localeDistribution.forEach(function(d) { %>
        <div class="flex items-center gap-3 mb-2">
          <span class="w-24 text-sm text-gray-400 truncate"><%= d.locale %></span>
          <div class="flex-1 bg-gray-800 rounded-full h-2">
            <div class="bg-sky-500 h-2 rounded-full" style="width: <%= Math.round(d.count/maxLocale*100) %>%"></div>
          </div>
          <span class="text-sm text-gray-400 w-10 text-right"><%= d.count %></span>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-gray-600 text-sm">Ingen lokaledata ennå</p>
    <% } %>
  </div>
</div>

<!-- Top 20 most wrongly answered questions (#267) -->
<% if (topWrongQuestions.length > 0) { %>
<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mt-6">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Topp 20 – oftest feilbesvarte spørsmål</div>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">#</th>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Spørsmål-ref</th>
        <th class="text-left px-4 py-2">Vanligste feil-svar</th>
        <th class="text-right px-4 py-2">Feil</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">Feil%</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% topWrongQuestions.forEach(function(r, i) { %>
        <% var errorPct = r.totalAttempts > 0 ? Math.round(r.wrongCount / r.totalAttempts * 100) : null %>
        <tr>
          <td class="px-4 py-2 text-gray-600"><%= i + 1 %></td>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-mono text-xs text-gray-300 max-w-xs truncate"><%= r.questionRef %></td>
          <td class="px-4 py-2 text-amber-400 max-w-xs truncate"><%= r.wrongAnswer %></td>
          <td class="px-4 py-2 text-right text-red-400"><%= r.wrongCount %></td>
          <td class="px-4 py-2 text-right text-gray-400"><%= r.totalAttempts %></td>
          <td class="px-4 py-2 text-right">
            <% if (errorPct !== null) { %>
              <span class="<%= errorPct >= 60 ? 'text-red-400' : errorPct >= 40 ? 'text-amber-400' : 'text-gray-400' %>"><%= errorPct %>%</span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
