<h1 class="text-2xl font-bold mb-6">Feedback <span class="text-gray-500 text-lg font-normal">(<%= total %>)</span></h1>

<div class="flex gap-2 mb-6">
  <% ['', 'open', 'in_progress', 'closed'].forEach(function(s) { %>
    <a href="/admin/feedback<%= s ? '?status=' + s : '' %>"
      class="px-3 py-1 rounded text-sm <%= statusFilter === s ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700' %>">
      <%= s || 'All' %>
    </a>
  <% }) %>
</div>

<div class="space-y-4">
  <% tickets.forEach(function(t) { %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5" id="ticket-<%= t.id %>">
      <!-- Header -->
      <div class="flex items-start justify-between mb-3">
        <div>
          <span class="font-medium"><%= t.user.avatarEmoji %> @<%= t.user.username %></span>
          <span class="ml-3 text-xs text-gray-500"><%= new Date(t.createdAt).toLocaleString() %></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded
            <%= t.status === 'open' ? 'bg-red-900 text-red-300' :
                t.status === 'in_progress' ? 'bg-amber-900 text-amber-300' : 'bg-gray-700 text-gray-400' %>">
            <%= t.status %>
          </span>
          <button onclick="deleteTicket('<%= t.id %>')"
            class="text-xs px-2 py-0.5 rounded bg-gray-800 hover:bg-red-900 text-gray-500 hover:text-red-300">
            Delete
          </button>
        </div>
      </div>

      <!-- User message -->
      <p class="text-sm text-gray-300 mb-3 whitespace-pre-wrap"><%= t.message %></p>

      <% if (t.imageUrl) { %>
        <a href="<%= t.imageUrl %>" target="_blank" class="text-xs text-indigo-400 hover:underline mb-3 inline-block">
          📎 Vedlagt bilde
        </a>
      <% } %>

      <!-- Admin response (latest) -->
      <% if (t.adminResponse) { %>
        <p class="text-sm text-indigo-300 border-l-2 border-indigo-600 pl-3 mb-3"><%= t.adminResponse %></p>
      <% } %>

      <!-- Thread comments -->
      <% if (t.comments && t.comments.length > 0) { %>
        <div class="space-y-2 mb-3 ml-3 border-l border-gray-700 pl-3">
          <% t.comments.forEach(function(c) { %>
            <div>
              <p class="text-sm text-gray-300 whitespace-pre-wrap"><%= c.body %></p>
              <span class="text-xs text-gray-600">
                <%= new Date(c.createdAt).toLocaleString() %>
                <%= c.notified ? '· 🔔 varslet' : '' %>
              </span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Actions -->
      <% if (t.status !== 'closed') { %>
        <!-- Respond & update status -->
        <form onsubmit="respond(event, '<%= t.id %>')" class="flex flex-wrap gap-2 mt-2 mb-2">
          <input name="response" placeholder="Skriv svar…"
            class="flex-1 min-w-0 bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500">
          <label class="flex items-center gap-1 text-xs text-gray-400 cursor-pointer">
            <input type="checkbox" name="notify" class="accent-indigo-500"> Varsle bruker
          </label>
          <button name="status" value="in_progress" type="submit"
            class="text-xs px-3 py-1.5 bg-gray-700 hover:bg-gray-600 rounded">Svar (behold åpen)</button>
          <button name="status" value="closed" type="submit"
            class="text-xs px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded">Svar & lukk</button>
        </form>

        <!-- Add comment without changing status -->
        <form onsubmit="addComment(event, '<%= t.id %>')" class="flex flex-wrap gap-2">
          <input name="commentBody" placeholder="Intern kommentar…"
            class="flex-1 min-w-0 bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:outline-none focus:border-gray-600">
          <label class="flex items-center gap-1 text-xs text-gray-400 cursor-pointer">
            <input type="checkbox" name="notifyComment" class="accent-indigo-500"> Varsle bruker
          </label>
          <button type="submit"
            class="text-xs px-3 py-1.5 bg-gray-700 hover:bg-gray-600 rounded">Legg til kommentar</button>
        </form>
      <% } %>
    </div>
  <% }) %>
</div>

<script>
async function respond(e, id) {
  e.preventDefault()
  const form = e.target
  const response = form.response.value.trim()
  if (!response) return
  const status = e.submitter?.value ?? 'in_progress'
  const notify = form.notify.checked
  await fetch('/admin/feedback/' + id, {
    method: 'PATCH',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ response, status, notify })
  })
  location.reload()
}

async function addComment(e, id) {
  e.preventDefault()
  const form = e.target
  const body = form.commentBody.value.trim()
  if (!body) return
  const notify = form.notifyComment.checked
  await fetch('/admin/feedback/' + id + '/comments', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ body, notify })
  })
  location.reload()
}

async function deleteTicket(id) {
  if (!confirm('Slette denne tilbakemeldingen? Kan ikke angres.')) return
  await fetch('/admin/feedback/' + id, { method: 'DELETE' })
  location.reload()
}
</script>
