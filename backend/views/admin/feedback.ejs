<h1 class="text-2xl font-bold mb-6">Feedback <span class="text-gray-500 text-lg font-normal">(<%= total %>)</span></h1>

<div class="flex gap-2 mb-6">
  <% ['', 'open', 'in_progress', 'closed'].forEach(function(s) { %>
    <a href="/admin/feedback<%= s ? '?status=' + s : '' %>"
      class="px-3 py-1 rounded text-sm <%= statusFilter === s ? 'bg-indigo-600 text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700' %>">
      <%= s || 'All' %>
    </a>
  <% }) %>
</div>

<div class="space-y-4">
  <% tickets.forEach(function(t) { %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-5" id="ticket-<%= t.id %>">
      <!-- Header -->
      <div class="flex items-start justify-between mb-3">
        <div>
          <span class="font-medium"><%= t.user.avatarEmoji %> @<%= t.user.username %></span>
          <span class="ml-3 text-xs text-gray-500"><%= fmtDateTime(t.createdAt) %></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded
            <%= t.status === 'open' ? 'bg-red-900 text-red-300' :
                t.status === 'in_progress' ? 'bg-amber-900 text-amber-300' : 'bg-gray-700 text-gray-400' %>">
            <%= t.status %>
          </span>
          <button onclick="deleteTicket('<%= t.id %>')"
            class="text-xs px-2 py-0.5 rounded bg-gray-800 hover:bg-red-900 text-gray-500 hover:text-red-300">
            Delete
          </button>
        </div>
      </div>

      <!-- User message -->
      <p class="text-sm text-gray-300 mb-3 whitespace-pre-wrap"><%= t.message %></p>

      <!-- Attached image -->
      <% if (t.imageUrl) { %>
        <a href="<%= t.imageUrl %>" target="_blank" class="inline-block mb-3">
          <img src="<%= t.imageUrl %>" alt="Vedlagt bilde"
            class="max-h-40 max-w-xs rounded-lg border border-gray-700 object-cover hover:opacity-90 transition-opacity">
        </a>
      <% } %>

      <!-- Thread comments -->
      <% if (t.comments && t.comments.length > 0) { %>
        <div class="space-y-2 mb-3 ml-3 border-l border-gray-700 pl-3">
          <% t.comments.forEach(function(c) { %>
            <div>
              <p class="text-sm text-gray-300 whitespace-pre-wrap"><%= c.body %></p>
              <span class="text-xs text-gray-600">
                <%= fmtDateTime(c.createdAt) %>
                <%= c.notified ? '· 🔔 varslet' : '' %>
              </span>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Status buttons -->
      <div class="flex gap-2 mb-3 mt-2">
        <% if (t.status !== 'open') { %>
          <button onclick="setStatus('<%= t.id %>', 'open')"
            class="text-xs px-2 py-0.5 rounded bg-gray-800 hover:bg-red-900 text-gray-400 hover:text-red-300">Åpne</button>
        <% } %>
        <% if (t.status !== 'in_progress') { %>
          <button onclick="setStatus('<%= t.id %>', 'in_progress')"
            class="text-xs px-2 py-0.5 rounded bg-gray-800 hover:bg-amber-900 text-gray-400 hover:text-amber-300">Behandles</button>
        <% } %>
        <% if (t.status !== 'closed') { %>
          <button onclick="setStatus('<%= t.id %>', 'closed')"
            class="text-xs px-2 py-0.5 rounded bg-gray-800 hover:bg-gray-700 text-gray-400">Lukk</button>
        <% } %>
      </div>

      <!-- Comment form -->
      <% if (t.status !== 'closed') { %>
        <form onsubmit="addComment(event, '<%= t.id %>')" class="flex flex-col gap-2">
          <textarea name="commentBody" placeholder="Kommenter…" rows="2"
            class="bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500 resize-none"></textarea>
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-1 text-xs text-gray-400 cursor-pointer">
              <input type="checkbox" name="notify" class="accent-indigo-500"> Varsle bruker
            </label>
            <button type="submit"
              class="text-xs px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded">Send</button>
          </div>
        </form>
      <% } %>
    </div>
  <% }) %>
</div>

<script>
async function setStatus(id, status) {
  await fetch('/admin/feedback/' + id, {
    method: 'PATCH',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ status })
  })
  location.reload()
}

async function addComment(e, id) {
  e.preventDefault()
  const form = e.target
  const body = form.commentBody.value.trim()
  if (!body) return
  const notify = form.notify.checked
  await fetch('/admin/feedback/' + id + '/comments', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ body, notify })
  })
  location.reload()
}

async function deleteTicket(id) {
  if (!confirm('Slette denne tilbakemeldingen? Kan ikke angres.')) return
  await fetch('/admin/feedback/' + id, { method: 'DELETE' })
  location.reload()
}
</script>
