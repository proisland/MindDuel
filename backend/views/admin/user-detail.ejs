<a href="/admin/users" class="text-sm text-gray-500 hover:text-white mb-4 inline-block">← Back to users</a>
<h1 class="text-2xl font-bold mb-6"><%= user.avatarEmoji %> @<%= user.username ?? '(no username)' %></h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 space-y-2 text-sm">
    <div class="flex justify-between"><span class="text-gray-400">ID</span><span class="font-mono text-xs"><%= user.id %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Premium</span><span><%= user.isPremium ? '✅' : '–' %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Flagged</span>
      <span class="<%= user.isFlagged ? 'text-amber-400' : 'text-gray-500' %>">
        <%= user.isFlagged ? '🚩 Yes' : 'No' %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Suspended</span>
      <span class="<%= user.isSuspended ? 'text-red-400' : 'text-gray-500' %>">
        <%= user.isSuspended ? '🚫 Yes' : 'No' %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Unlimited quota</span>
      <span class="<%= user.isUnlimited ? 'text-green-400' : 'text-gray-500' %>">
        <%= user.isUnlimited ? '♾️ Yes' : 'No' %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Fast rounds</span><span><%= user.fastRoundCount %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Total rounds</span><span><%= totalRounds %></span></div>
    <% if (quota) { %>
    <div class="flex justify-between"><span class="text-gray-400">Dagskvote</span>
      <span class="<%= quota.used >= quota.limit ? 'text-red-400' : 'text-gray-300' %>">
        <%= quota.used %>/<%= quota.limit %>
        <% if (!quota.isToday) { %><span class="text-gray-600 text-xs">(<%= quota.date %>)</span><% } %>
      </span></div>
    <% } %>
    <div class="flex justify-between"><span class="text-gray-400">Last active</span>
      <span><%= fmtDateTime(user.lastActiveAt) %></span></div>
    <div class="flex justify-between"><span class="text-gray-400">Joined</span>
      <span><%= fmtDate(user.createdAt) %></span></div>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
    <h2 class="font-semibold mb-3">Actions</h2>
    <div class="flex flex-wrap gap-2">
      <button onclick="patch({isFlagged: <%= !user.isFlagged %>})"
        class="text-sm px-3 py-1.5 bg-gray-700 hover:bg-amber-800 rounded">
        <%= user.isFlagged ? 'Remove flag' : 'Flag account' %>
      </button>
      <button onclick="patch({isSuspended: <%= !user.isSuspended %>})"
        class="text-sm px-3 py-1.5 bg-gray-700 hover:bg-red-800 rounded">
        <%= user.isSuspended ? 'Unsuspend' : 'Suspend account' %>
      </button>
      <button onclick="patch({isUnlimited: <%= !user.isUnlimited %>})"
        class="text-sm px-3 py-1.5 bg-gray-700 hover:bg-green-800 rounded">
        <%= user.isUnlimited ? 'Remove unlimited' : 'Grant unlimited quota' %>
      </button>
    </div>
  </div>
</div>

<div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
  <% user.progressions.forEach(function(p) { %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-3 text-sm">
      <div class="text-gray-400 text-xs mb-1"><%= p.mode %></div>
      <div class="font-bold text-lg">Lv <%= p.position %></div>
      <div class="text-gray-500 text-xs"><%= Math.round(p.progress*100) %>% to next</div>
    </div>
  <% }) %>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Per-mode stats</div>
  <% if (modeStats.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Mode</th>
        <th class="text-right px-4 py-2">Rounds</th>
        <th class="text-right px-4 py-2">Questions</th>
        <th class="text-right px-4 py-2">Correct</th>
        <th class="text-right px-4 py-2">% correct</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% modeStats.forEach(function(s) { %>
        <tr>
          <td class="px-4 py-2 font-medium"><%= s.mode %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= s.rounds %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= s.answered %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= s.correct %></td>
          <td class="px-4 py-2 text-right">
            <% if (s.pctCorrect !== null) { %>
              <span class="<%= s.pctCorrect >= 70 ? 'text-green-400' : s.pctCorrect >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= s.pctCorrect %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen fullførte spilløkter ennå</p>
  <% } %>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden mb-8">
  <div class="bg-gray-800 px-4 py-2 font-semibold text-sm">Per-nivå nøyaktighet</div>
  <% if (levelStats.length > 0) { %>
  <table class="w-full text-sm">
    <thead class="text-gray-500 text-xs">
      <tr>
        <th class="text-left px-4 py-2">Modus</th>
        <th class="text-left px-4 py-2">Nivå</th>
        <th class="text-right px-4 py-2">Riktige</th>
        <th class="text-right px-4 py-2">Totalt</th>
        <th class="text-right px-4 py-2">% riktig</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% levelStats.forEach(function(r) { %>
        <tr>
          <td class="px-4 py-2 text-gray-400"><%= r.mode %></td>
          <td class="px-4 py-2 font-medium"><%= r.level %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.correct %></td>
          <td class="px-4 py-2 text-right text-gray-300"><%= r.total %></td>
          <td class="px-4 py-2 text-right">
            <% if (r.pct !== null) { %>
              <span class="<%= r.pct >= 70 ? 'text-green-400' : r.pct >= 50 ? 'text-amber-400' : 'text-red-400' %>">
                <%= r.pct %>%
              </span>
            <% } else { %>
              <span class="text-gray-600">–</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% } else { %>
    <p class="text-gray-600 text-sm px-4 py-3">Ingen data ennå</p>
  <% } %>
</div>

<script>
async function patch(data) {
  await fetch('/admin/users/<%= user.id %>', {
    method: 'PATCH',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify(data)
  })
  location.reload()
}
</script>
