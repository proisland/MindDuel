<h1 class="text-2xl font-bold mb-6">Preset Avatars</h1>

<!-- Create form -->
<div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-6">
  <h2 class="font-semibold mb-3">Add preset avatar</h2>
  <form onsubmit="createAvatar(event)" class="flex flex-wrap gap-2 items-end">
    <div>
      <label class="block text-xs text-gray-400 mb-1">Image URL</label>
      <input name="url" placeholder="https://..." required
        class="bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500 w-80">
    </div>
    <div>
      <label class="block text-xs text-gray-400 mb-1">Label (optional)</label>
      <input name="label" placeholder="e.g. Fox"
        class="bg-gray-800 border border-gray-700 rounded px-3 py-1.5 text-sm text-white focus:outline-none focus:border-indigo-500 w-32">
    </div>
    <button type="submit"
      class="bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium px-4 py-1.5 rounded transition">
      Add
    </button>
  </form>
</div>

<!-- Avatars grid -->
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
  <% avatars.forEach(function(av) { %>
  <div class="bg-gray-900 border border-gray-800 rounded-xl p-3 flex flex-col items-center gap-2">
    <img src="<%= av.url %>" alt="<%= av.label || 'avatar' %>"
      class="w-16 h-16 rounded-full object-cover border border-gray-700"
      onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><circle cx=%2250%22 cy=%2250%22 r=%2250%22 fill=%22%23374151%22/></svg>'">
    <span class="text-xs text-gray-400 text-center truncate w-full"><%= av.label || '—' %></span>
    <div class="flex gap-1 w-full">
      <button onclick="toggleAvatar('<%= av.id %>', <%= av.isActive %>)"
        class="flex-1 text-xs px-2 py-1 rounded <%= av.isActive ? 'bg-green-900 text-green-300' : 'bg-gray-700 text-gray-400' %> hover:opacity-80 transition">
        <%= av.isActive ? 'Active' : 'Inactive' %>
      </button>
      <button onclick="deleteAvatar('<%= av.id %>')"
        class="text-xs px-2 py-1 rounded bg-red-900 text-red-300 hover:opacity-80 transition">
        ✕
      </button>
    </div>
  </div>
  <% }) %>
  <% if (avatars.length === 0) { %>
  <p class="col-span-full text-gray-500 text-sm">No preset avatars yet. Add one above.</p>
  <% } %>
</div>

<script>
async function createAvatar(e) {
  e.preventDefault()
  const fd = new FormData(e.target)
  const res = await fetch('/admin/avatars', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ url: fd.get('url'), label: fd.get('label') || '' }),
  })
  if (res.ok) location.reload()
  else alert('Error: ' + (await res.json()).error)
}

async function toggleAvatar(id, isActive) {
  await fetch(`/admin/avatars/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ isActive: !isActive }),
  })
  location.reload()
}

async function deleteAvatar(id) {
  if (!confirm('Delete this preset avatar?')) return
  await fetch(`/admin/avatars/${id}`, { method: 'DELETE' })
  location.reload()
}
</script>
