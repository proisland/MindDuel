<h1 class="text-2xl font-bold mb-6">Question Packs</h1>

<div class="mb-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
  <h2 class="font-semibold mb-3">Upload new pack (JSON)</h2>
  <p class="text-sm text-gray-400 mb-3">POST a JSON body to <code class="bg-gray-800 px-1 rounded">/admin/questions</code> with <code class="bg-gray-800 px-1 rounded">{ mode, questions: [{id, prompt, options[4], answer, level}] }</code></p>
  <p class="text-sm text-gray-500">The pack starts inactive. Use "Activate" below to make it live.</p>
</div>

<div class="space-y-6">
  <% Object.entries(grouped).forEach(function([mode, packs]) { %>
    <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
      <div class="bg-gray-800 px-4 py-2 font-semibold text-indigo-300"><%= mode %></div>
      <table class="w-full text-sm">
        <thead class="text-gray-500 text-xs">
          <tr>
            <th class="text-left px-4 py-2">Version</th>
            <th class="text-left px-4 py-2">Status</th>
            <th class="text-left px-4 py-2">Created</th>
            <th class="text-left px-4 py-2">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% packs.forEach(function(p) { %>
            <tr>
              <td class="px-4 py-2">v<%= p.version %></td>
              <td class="px-4 py-2">
                <%= p.isActive
                  ? '<span class="text-green-400 text-xs">● Active</span>'
                  : '<span class="text-gray-500 text-xs">Inactive</span>' %>
              </td>
              <td class="px-4 py-2 text-gray-500 text-xs"><%= new Date(p.createdAt).toLocaleDateString() %></td>
              <td class="px-4 py-2">
                <% if (!p.isActive) { %>
                  <button onclick="activate('<%= p.id %>')"
                    class="text-xs px-2 py-1 bg-green-900 hover:bg-green-800 text-green-300 rounded">
                    Activate
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% }) %>
</div>

<script>
async function activate(id) {
  await fetch('/admin/questions/' + id + '/activate', { method: 'PATCH' })
  location.reload()
}
</script>
