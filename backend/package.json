    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "ejs": "^3.1.10",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.1",
